# Pulse dashboard — local dev port (3000 is often used by other projects)
PORT=3001

# AWS region for DynamoDB and DSQL
AWS_REGION=eu-west-2

# DynamoDB single-table event stream
DYNAMODB_TABLE_NAME=pulse_event_stream

# Aurora DSQL cluster endpoint (merchant directory + subscriptions)
DSQL_CLUSTER_ENDPOINT=your-cluster.dsql.us-west-2.on.aws

# WhatsApp Business API token for OTP and Agent message delivery
WHATSAPP_API_TOKEN=

# Bedrock Nova Lite for paper ledger vision ingestion (region: us-west-2, uses AWS credentials)
# BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
